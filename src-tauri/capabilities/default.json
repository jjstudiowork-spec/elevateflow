    "core:resources:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-home-write-recursive",
    "fs:allow-home-read-recursive",
    "fs:allow-desktop-write-recursive",
